# ───────────────────────────────────────────────────────────────────────
# Ledger Sentinel — environment configuration  (OPS ONLY)
#
# There are deliberately NO model settings here. The agent always boots in
# DETERMINISTIC MOCK mode; the provider, API key, and model are chosen entirely
# from the dashboard (⚙️) at runtime — pick a provider, paste a key, fetch the
# models that key can use, select one, done. Nothing about the model stack is
# decided from the environment.
#
# Everything below is optional ops config for the deployment itself.
# ───────────────────────────────────────────────────────────────────────

# Optional admin token. If set, configuration writes (PUT /config, /config/test,
# model fetch) require an `X-Admin-Token` header — a lightweight guard on the
# key-bearing control plane. Leave blank for an open, zero-config local/demo.
LEDGER_ADMIN_TOKEN=

# AgentOps / observability (optional). If unset, traces are kept in-process
# and still rendered on the AgentOps tab — Langfuse just adds persistence.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Confidence gate: extractions below this route to the QUARANTINE lane.
LEDGER_CONFIDENCE_THRESHOLD=0.80

# Reconciliation fuzzy-match acceptance threshold (0-1).
LEDGER_MATCH_THRESHOLD=0.82

# Max extraction workers to fan out concurrently.
LEDGER_MAX_CONCURRENCY=8
